{
  "name": "maltipoo",
  "version": "2.1.2",
  "description": "Base stylesheet for DataCite",
  "scripts": {
    "clean": "rimraf dist",
    "build": "yarn clean && yarn sass src/stylesheets/doi.scss dist/stylesheets/doi.css && postcss dist/stylesheets/doi.css -o dist/stylesheets/doi.min.css"
  },
  "main": "dist/stylesheets/doi.min.css",
  "repository": "https://github.com/datacite/maltipoo",
  "license": "MIT",
  "devDependencies": {
    "bootstrap": "^5.3.3",
    "bootstrap-sass": "^3.4.3",
    "cssnano": "^8.0.2",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "rimraf": "^6.1.3",
    "sass": "^1.100.0"
  },
  "packageManager": "yarn@4.16.0+sha512.5374c94eb4ef6aa8188fb112f20c1aa6569f248d676c5e576e1fd2a1a4d8d87a96df65d9dfe1c2a0252cbe38bda46cf18d955005b81b43cc7607a5c9d56fd2b6"
}
